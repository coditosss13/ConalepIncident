# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gestion_incidencias
DB_USER=root
DB_PASSWORD=tu_password

# JWT
JWT_SECRET=cambiar_por_un_secret_largo_y_aleatorio
JWT_EXPIRES_IN=8h

# Rate limit (auth)
AUTH_RATE_WINDOW_MS=900000
AUTH_RATE_MAX_REQUESTS=10
REFRESH_RATE_WINDOW_MS=900000
REFRESH_RATE_MAX_REQUESTS=20
LOGIN_FAIL_THRESHOLD=5
LOGIN_LOCK_BASE_MS=60000
LOGIN_LOCK_MAX_MS=1800000